# ============================================
# Configuración de PostgreSQL
# ============================================
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=changeme_in_local
POSTGRES_DB=chatbot_mantenimiento
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL completa usada por SQLAlchemy en el backend
DATABASE_URL=postgresql+psycopg://chatbot:changeme_in_local@postgres:5432/chatbot_mantenimiento

# ============================================
# Backend (FastAPI)
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development
LOG_LEVEL=INFO

# ============================================
# OpenAI (no se usa en Hito 1, ya reservado)
# ============================================
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL_LLM=gpt-4o-mini
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small

# ============================================
# Seguridad (no se usa en Hito 1, ya reservado)
# ============================================
JWT_SECRET=replace-with-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API key para endpoints internos (n8n ↔ backend)
INTERNAL_API_KEY=replace-with-random-string

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000
